# MiMo API Configuration
MIMO_API_KEY=your_mimo_api_key_here
MIMO_API_URL=https://api.mimo.com/v1

# Server Configuration
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=sqlite:./data/mimo.db

# Redis
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=your_jwt_secret_here
API_SECRET=your_api_secret_here

# Mobile Push Notifications
PUSH_PROVIDER=jiguang
JPUSH_APP_KEY=your_jpush_app_key
JPUSH_MASTER_SECRET=your_jpush_master_secret

# Device Discovery
ENABLE_MDNS=true
MDNS_SERVICE_NAME=mimo-agent

# WebSocket
WS_PING_INTERVAL=30000
WS_PING_TIMEOUT=10000

# Logging
LOG_LEVEL=info
