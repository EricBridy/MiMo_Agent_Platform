# MiMo Agent Platform Environment Configuration

# Database
DATABASE_URL="file:./dev.db"

# Redis (optional)
REDIS_URL="redis://localhost:6379"

# JWT Secret
JWT_SECRET="your-jwt-secret-here"

# API Secret
API_SECRET="your-api-secret-here"

# Mock API Port
MOCK_API_PORT=3002

# Gateway Port
GATEWAY_PORT=3001

# Log Level
LOG_LEVEL="debug"
