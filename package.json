{
  "name": "mimo-agent-platform",
  "version": "1.0.0",
  "description": "MiMo大模型Agent编程开发平台 - 跨平台AI编程工具",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev:desktop": "npm run dev --workspace=apps/desktop",
    "dev:mobile": "npm run dev --workspace=apps/mobile",
    "dev:cli": "npm run dev --workspace=apps/cli",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:mock-api": "node services/mock-api/simple-server.js",
    "dev:services": "npm run dev --workspace=services/gateway",
    "build:desktop": "npm run build --workspace=apps/desktop",
    "build:mobile": "npm run build --workspace=apps/mobile",
    "build:cli": "npm run build --workspace=apps/cli",
    "build:packages": "npm run build --workspace=packages/core",
    "package:desktop": "npm run package --workspace=apps/desktop",
    "package:desktop:win": "npm run package --workspace=apps/desktop -- --win",
    "package:desktop:mac": "npm run package --workspace=apps/desktop -- --mac",
    "package:desktop:linux": "npm run package --workspace=apps/desktop -- --linux",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "publish:all": "npm run publish --workspaces --if-present",
    "clean": "rm -rf **/dist **/node_modules **/coverage",
    "release": "standard-version"
  },
  "keywords": [
    "mimo",
    "agent",
    "ai-coding",
    "cross-platform",
    "electron",
    "react-native"
  ],
  "author": "Eric Bridy",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2"
  }
}
